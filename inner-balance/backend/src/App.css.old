:root {
  --bg: #f4f8ff;
  --card: #ffffff;
  --text: #23374d;
  --muted: #556877;
  --primary: #3f7edb;
  --primary-dark: #2f62b4;
  --accent: #6bdeca;
  --danger: #e74c3c;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: "Inter", "Roboto", "Segoe UI", sans-serif;
  background: var(--bg);
  color: var(--text);
}

.app-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px 30px;
  background: linear-gradient(120deg, #3f7edb, #1fc8db);
  color: #ffffff;
  box-shadow: 0 3px 16px rgba(0, 0, 0, 0.12);
}

.navbar .brand {
  font-weight: 800;
  font-size: 1.25rem;
}

.navbar nav a {
  margin-left: 14px;
  color: #ffffff;
  text-decoration: none;
  font-weight: 600;
  border: 1px solid rgba(255,255,255,0.3);
  padding: 7px 12px;
  border-radius: 8px;
  transition: all 0.2s ease;
}

.navbar nav a:hover {
  background: rgba(255,255,255,0.18);
}

.main-content {
  flex: 1;
  padding: 30px;
}

.container {
  max-width: 1080px;
  margin: 0 auto;
  padding: 10px;
}

.hero-section {
  background: linear-gradient(120deg, #ffffff, #eaf5ff);
  padding: 40px;
  border-radius: 18px;
  text-align: center;
  margin-bottom: 24px;
  box-shadow: 0 8px 24px rgba(30, 80, 140, 0.12);
}

.hero-section h1 {
  margin: 0;
  font-size: 2.5rem;
  letter-spacing: 0.01em;
}

.hero-section p {
  color: var(--muted);
  font-size: 1.1rem;
  margin-top: 10px;
}

.hero-actions {
  margin-top: 22px;
}

.btn {
  display: inline-block;
  margin: 5px;
  padding: 11px 20px;
  border-radius: 10px;
  font-weight: 600;
  border: none;
  text-decoration: none;
}

.btn.primary {
  background: var(--primary);
  color: #fff;
}

.btn.secondary {
  background: #fff;
  color: var(--primary-dark);
  border: 1px solid var(--primary);
}

.btn.primary:hover {
  background: var(--primary-dark);
}

.btn.secondary:hover {
  background: #eef6ff;
}

.home-page .features {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}

.card {
  background: var(--card);
  border: 1px solid #dbe9ff;
  border-radius: 14px;
  padding: 20px;
  box-shadow: 0 10px 25px rgba(41, 120, 191, 0.08);
}

.card h3 {
  margin: 0 0 10px;
}

.card p {
  margin: 0;
  color: var(--muted);
}

input,
button {
  font-family: inherit;
}

input {
  width: 100%;
  max-width: 320px;
  padding: 10px;
  border: 1px solid #b5c8e7;
  border-radius: 10px;
  margin-bottom: 14px;
}

button[type="submit"] {
  background: var(--primary);
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 10px 18px;
  font-weight: 700;
  cursor: pointer;
}

button[type="submit"]:hover {
  background: var(--primary-dark);
}

.login-form,
.signup-form {
  max-width: 420px;
  margin: 0 auto;
  background: #fff;
  border: 1px solid #dbe9ff;
  padding: 28px;
  border-radius: 16px;
  box-shadow: 0 10px 30px rgba(20, 80, 160, 0.08);
}

.login-form h2,
.signup-form h2 {
  text-align: center;
  margin-bottom: 16px;
}

@media (max-width: 768px) {
  .navbar {
    flex-wrap: wrap;
    gap: 12px;
  }

  .main-content {
    padding: 18px;
  }
}
